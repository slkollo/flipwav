      <tbody>
        <tr><td>FLAC</td><td class="bad">~35 MB</td><td class="good">Perfect</td><td class="ok">Limited apps</td></tr>
        <tr><td>MP3 320kbps</td><td class="good">~9 MB</td><td class="good">Excellent</td><td class="good">Universal</td></tr>
        <tr><td>MP3 192kbps</td><td class="good">~6 MB</td><td class="good">Very Good</td><td class="good">Universal</td></tr>
        <tr><td>MP3 128kbps</td><td class="good">~4 MB</td><td class="ok">Good</td><td class="good">Universal</td></tr>
      </tbody>
    </table>
  </div>

